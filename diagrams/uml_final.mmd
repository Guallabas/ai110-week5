classDiagram
    class Owner {
        +name: str
        +preferences: List[str]
        +pets: List[Pet]
        +add_pet(pet: Pet) void
        +update_preferences(preferences: List[str]) void
        +get_all_tasks() List[Task]
        +get_pending_tasks() List[Task]
    }

    class Pet {
        +name: str
        +species: str
        +tasks: List[Task]
        +add_task(task: Task) void
        +get_tasks() List[Task]
        +get_pending_tasks() List[Task]
        +task_count() int
    }

    class Task {
        +description: str
        +time: str
        +frequency: str
        +completed: bool
        +priority: str
        +date: Optional[str]
        +mark_complete() void
        +is_completed() bool
    }

    class Scheduler {
        +retrieve_tasks(owner: Owner) List[Task]
        +sort_tasks(tasks: List[Task]) List[Task]
        +sort_by_time(tasks: List[Task]) List[Task]
        +filter_tasks(tasks: List[Task], completed: Optional[bool]) List[Task]
        +tasks_for_pet(owner: Owner, pet_name: str) List[Task]
        +sort_and_filter(owner: Owner, completed: Optional[bool], pet_name: Optional[str]) List[Task]
        +mark_task_complete(owner: Owner, pet_name: str, task: Task) Optional[Task]
        +find_conflicts(owner: Owner) List[str]
        +build_daily_schedule(owner: Owner) List[Task]
        +format_schedule(owner: Owner) str
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler ..> Owner : manages
    Scheduler ..> Pet : organizes
    Scheduler ..> Task : prioritizes
